// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// SEGURANÇA — Não commitar valores reais. Copiar para `TruckerEasy.secrets.xcconfig` (gitignored).
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
//
// 1) Copiar:  cp Config/TruckerEasy.secrets.example.xcconfig Config/TruckerEasy.secrets.xcconfig
// 2) Preencher secções abaixo. O target já inclui este ficheiro via TruckerEasy.debug/release.xcconfig
// 3) URLs: em .xcconfig `//` inicia comentário — usar `http:||host` ou `https:||host`.
//    O Swift converte `||` → `//` ao ler (ValhallaRoutingService / RoutingService / quantum client).
// 4) iPhone físico: não uses `*.local` / localhost no URL — usa IP LAN ou túnel HTTPS (ngrok).
// 5) ATS: em dev, adicionar exceções NSExceptionDomains no Info.plist para hosts HTTP;
//    em produção usar sempre HTTPS.
// 6) Valhalla: a cobertura de mapa tem de incluir a região onde testas (ex.: tiles só Mónaco
//    não servem para rotas nos EUA).
//
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// A) Geometria de estrada (polyline no mapa) — CAMIÃO vs CARRO
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
//
// Motor **truck-aware** integrado: apenas **Valhalla** com costing `truck` (altura, peso/GVW, comprimento,
// hazmat, pedágios conforme pedido). OSRM público e Apple MapKit são **perfil automóvel**: não aplicam
// restrições legais de pesados — o app marca aviso na rota (`non_truck_routing`) se forem usados.
//
// **Execução global (produção)** — para o GPS/nav não depender da LAN do Mac:
//   1) Hospedar Valhalla com HTTPS e tiles da região onde operas (ver `backend/valhalla-production/README.md`).
//   2) Preencher VALHALLA_SERVER_URL com esse URL (ex.: https:||valhalla.teudominio.com).
//   3) Opcional: VALHALLA_SERVER_URLS com **vários** endpoints — são tentados por ordem **depois** de ordenar:
//      sempre **HTTPS antes de HTTP**. Exemplo (cloud primeiro, LAN só como backup em dev):
//        VALHALLA_SERVER_URLS = https:||valhalla.teudominio.com,http:||192.168.0.105:8002
//   4) No app: ativar **modo só truck-safe** (preferências) para **recusar** OSRM/MapKit quando Valhalla falhar
//      — obriga operação só com geometria validada para camião (evita “rota de carro” silenciosa).
//   5) GPS (Core Location): funciona em todo o mundo com vista ao céu/rede; não substitui servidor de rotas.
//   6) Modo teste: `AppAccessPolicy.unlockAllFeaturesForTesting = true` em UtilitiesAppDistributionConfig.swift
//      (Premium + Valhalla-only). Mudar para `false` antes do App Store.
//
// Valhalla — URL base SEM `/route` no fim. Ex.: http:||192.168.0.105:8002 (Opção 3: geometria na 8002)
// Produção US+Canada (4G / TestFlight): https:||valhalla.truckereasy.com
// Tiles: `backend/valhalla-production/deploy.sh` (Geofabrik US + Canada merge)
VALHALLA_SERVER_URL = https:||valhalla.truckereasy.com
// Cloud primeiro, LAN só backup em dev — HTTPS tentado antes de HTTP automaticamente.
VALHALLA_SERVER_URLS = https:||valhalla.truckereasy.com
// Dev LAN (descomentar e acrescentar à lista acima, separado por vírgula):
// VALHALLA_SERVER_URLS = https:||valhalla.truckereasy.com,http:||192.168.0.105:8002

// App Store / TestFlight — preencher quando tiveres link público (site Lovable usa o mesmo texto de preço).
// Ex.: https:||apps.apple.com/app/id1234567890  ou  https:||testflight.apple.com/join/AbCdEfGh
APP_STORE_URL =
TESTFLIGHT_URL =

// OSRM — URL base SEM `/route/...`. Vazio → app usa demo público router.project-osrm.org
// (útil se não tiveres OSRM local; evita conflito com outros serviços na porta 5000 do Mac).
OSRM_SERVER_URL =

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// B) Otimização de ordem de paragens (POST /v1/optimize — Python no repo `backend/quantum-routing`)
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

// Produção/TestFlight: usar HTTPS via Supabase Edge Function `route-proxy`.
// Ex.: https:||PROJECT.supabase.co/functions/v1/route-proxy
// O upstream real (mesmo se for http://IP:8003) deve ficar em secrets da Edge Function:
//   ROUTE_OPTIMIZATION_UPSTREAM_URL
//   ROUTE_OPTIMIZATION_UPSTREAM_API_KEY
// Nunca coloque IP HTTP público nem chave privada do upstream no app.
ROUTE_OPTIMIZATION_API_BASE_URL =
ROUTE_OPTIMIZATION_API_KEY =

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// C) Mapa / backend cloud (opcional em dev local)
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

// mapbox.com/account/access-tokens — pk.eyJ… (never wrap in parentheses in plist/xcconfig)
MBXAccessToken =
// Supabase → Project Settings → API → Project URL (same project as SUPABASE_ANON_KEY).
// Use https:||ref.supabase.co — not https:// — because // starts an xcconfig line comment.
SUPABASE_URL =
// PostgREST (/rest/v1) needs the JWT anon key (long string starting with eyJ…).
// Do not use sb_publishable_… here — that key returns HTTP 401 from this app’s REST client.
// Dashboard: Project Settings → API → Project API keys → anon / public (legacy JWT).
SUPABASE_ANON_KEY =

AgoraAppID =
NewsAPIKey =
OpenRouterAPIKey =
OpenWeatherMapAPIKey =
TomTomAPIKey =

// --- E) Lotus.ai — partner link only (no API; user opens Lotus site in Safari) ---
LOTUS_CORTEX_WEB_BASE_URL = https:||lotus.ai

// --- F) Telemedicine (DoctorsHero — https://developers.doctorshero.com) ---
// Bearer token for DoctorsHero REST API. Get it from your developer dashboard.
DoctorsHeroAPIKey =

ELDProviderAPIKey =
ELDProviderBaseURL =
ELDVehicleID =
OBD2BLEDeviceName =
JurisdictionPolicyAPIBaseURL =
JurisdictionPolicyAPIKey =
OperationalFeedAPIBaseURL =
OperationalFeedAPIKey =
OperationalFeedProviderURLs =
