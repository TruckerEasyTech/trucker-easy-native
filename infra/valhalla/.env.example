# Copy to .env on the Valhalla host.
VALHALLA_PORT=8002
VALHALLA_SERVER_THREADS=4
VALHALLA_FORCE_REBUILD=False

# Default: United States extract. For all North America, use:
# PBF_URL=https://download.geofabrik.de/north-america-latest.osm.pbf
PBF_URL=https://download.geofabrik.de/north-america/us-latest.osm.pbf
