SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# --- FREE (register / no card) ---
# Ohio OHGO truck parking — https://publicapi.ohgo.com/accounts/registration
# Auth header: Authorization: APIKEY {key}
OHGO_API_KEY=

# I-10 TPAS dynamic feeds (per state DOT — request URL from i10connects.com/resources)
# Format: GET .../api/TPAS_Dynamic.json + companion TPAS_Static.json for lat/lon
# Example (when your state provides it): https://drivetexas.org/api/TPAS_Dynamic.json
TPIMS_DYNAMIC_URLS=

# Ontario 511 + Caltrans + BC CVSE — NO KEY (sync_public_truck_feeds.py)

# --- PAID / OPTIONAL ---
# HERE — commercial POI browse (developer.here.com). App: HERE_API_KEY in xcconfig.
HERE_API_KEY=

# Road511 — ALREADY in Supabase Edge secrets (not needed here for sync_partner_feeds.py)
# Dashboard → Edge Functions → Secrets: ROAD511_API_KEY + ENABLE_ROAD511=true
# NextBillion — optional catalog (nextbillion.ai) → Supabase secret NEXTBILLION_API_KEY

# Required for sync_partner_feeds.py / sync_operational_feeds.py on EC2
SUPABASE_ANON_KEY=
