SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Optional — Ohio OHGO truck parking (register at publicapi.ohgo.com)
OHGO_API_KEY=

# Optional — HERE Geocoding & Search (browse truck POIs). Commercial license required.
HERE_API_KEY=

# Comma-separated TPIMS dynamic JSON URLs (IL, KY, MN, TX I-10 coalition format)
# Example: https://example.state.gov/api/TPAS_Dynamic.json
TPIMS_DYNAMIC_URLS=

# --- Partner feeds (set same keys in Supabase Edge Function secrets) ---
# Road511 — aggregates state 511/DOT/NBI weigh + truck parking (https://road511.com)
ROAD511_API_KEY=

# NextBillion — Browse API for truck_stop / rest_area POI (https://nextbillion.ai)
NEXTBILLION_API_KEY=

# Supabase anon key — used by sync_partner_feeds.py to call trucking-poi-feed
SUPABASE_ANON_KEY=
