# Copiar para .env (nunca commitar .env — está no .gitignore em backend/ e na raiz).
# Depois de criar .env: chmod 600 .env  (só o teu utilizador lê/escreve).
#
# Credenciais AWS: em produção usar IAM role (ECS/EKS/Lambda/EC2) — sem ficheiro com secret.
# Em dev local: preencher só neste .env ou usar `aws configure` (~/.aws/credentials fora do repo).
# Nunca colar keys em código, Git, Slack, Cursor chat ou tickets.

AWS_DEFAULT_REGION=us-west-2
AWS_REGION=us-west-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Produção EC2 / TestFlight (recomendado) ---
# Greedy nearest-neighbour — sem D-Wave, Braket ou credenciais AWS.
ROUTE_OPT_SOLVER=greedy
DISABLE_DWAVE=1
USE_AMAZON_BRAKET=0
USE_TSP_SA_SIMULATOR=0

# Opcional: TSP clássico (CPU) em vez de greedy puro — ainda sem D-Wave:
# USE_TSP_SA_SIMULATOR=1

# --- Labs / dev only (ROUTE_OPT_SOLVER=hybrid + DISABLE_DWAVE=0) ---
# Modo quântico (AWS Braket → D-Wave): USE_AMAZON_BRAKET=1 exige também
# BRAKET_RESULTS_S3_BUCKET, BRAKET_DWAVE_DEVICE_ARN e credenciais AWS (ou IAM role) em us-west-2 (Oregon).
# 0 = sem Braket (Neal/Leap/greedy; útil sem conta Braket). 1 = tentar QPU via Braket primeiro.
USE_AMAZON_BRAKET=0
# Bucket S3 na mesma região (Braket grava resultados das tasks)
BRAKET_RESULTS_S3_BUCKET=your-s3-bucket-us-west-2
BRAKET_RESULTS_S3_PREFIX=truckereasy-braket/
# ARN copiado da consola Braket → Devices (deve coincidir com a região)
BRAKET_DWAVE_DEVICE_ARN=
BRAKET_NUM_READS=50

# Plano B — TSP clássico (força bruta n<=8, Simulated Annealing n>8), sem D-Wave na nuvem.
# 1 = usa SA clássico antes de greedy (funciona com ROUTE_OPT_SOLVER=greedy).
USE_TSP_SA_SIMULATOR=0
# DISABLE_DWAVE=1  (default em produção — ver ROUTE_OPT_SOLVER acima)

# Leap (opcional; cadeia: Braket se USE_AMAZON_BRAKET → senão Leap Hybrid → Neal → greedy)
# DWAVE_API_TOKEN=

# API Gateway: vazio = não exige X-API-Key. Se preencheres, o iOS (xcconfig) e o curl têm de enviar o mesmo valor.
ROUTE_OPTIMIZATION_API_KEY=

# iOS / rede local
# - O app lê `ROUTE_OPTIMIZATION_API_BASE_URL` no Info.plist (via Config/TruckerEasy.secrets.xcconfig).
# - iPhone no Wi‑Fi: `GET http://SEU_IP:PORTA/status` ou `/health` → JSON com "status":"ok".
# - Arranque (a partir desta pasta): `uvicorn app.main:app --host 0.0.0.0 --port 8787` (módulo `app.main`, não `main:app`).
# - Após mudar .env: reiniciar o processo uvicorn.
# - CORS: por defeito `CORS_ALLOW_ORIGINS=*` no main.py (dev). Em produção restringe origens.

# --- Lotus.ai Cortex (wellness / telehealth — NÃO colocar no iOS) ---
LOTUS_CORTEX_API_KEY=
LOTUS_CORTEX_API_BASE_URL=https://api.lotus.ai/v1/cortex
LOTUS_CORTEX_WEB_BASE_URL=https://lotus.ai/cortex/auth
