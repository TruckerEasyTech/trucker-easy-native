<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>AgoraAppID</key>
	<string>$(AgoraAppID)</string>
	<key>CFBundleLocalizations</key>
	<array>
		<string>en</string>
		<string>es</string>
		<string>pt-BR</string>
		<string>fr-CA</string>
	</array>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLName</key>
			<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>truckereasy</string>
			</array>
		</dict>
	</array>
	<key>DoctorsHeroAPIKey</key>
	<string>$(DoctorsHeroAPIKey)</string>
	<key>ELDProviderAPIKey</key>
	<string>$(ELDProviderAPIKey)</string>
	<key>ELDProviderBaseURL</key>
	<string>$(ELDProviderBaseURL)</string>
	<key>ELDVehicleID</key>
	<string>$(ELDVehicleID)</string>
	<key>JurisdictionPolicyAPIBaseURL</key>
	<string>$(JurisdictionPolicyAPIBaseURL)</string>
	<key>JurisdictionPolicyAPIKey</key>
	<string>$(JurisdictionPolicyAPIKey)</string>
	<key>MBXAccessToken</key>
	<string>$(MBXAccessToken)</string>
	<key>NewsAPIKey</key>
	<string>$(NewsAPIKey)</string>
	<key>MKDirectionsApplicationSupportedModes</key>
	<array>
		<string>MKDirectionsModeTruck</string>
	</array>
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<false/>
		<key>NSExceptionDomains</key>
		<dict>
			<key>newsapi.org</key>
			<dict>
				<key>NSIncludesSubdomains</key>
				<true/>
				<key>NSTemporaryExceptionAllowsInsecureHTTPLoads</key>
				<false/>
			</dict>
			<key>router.hereapi.com</key>
			<dict>
				<key>NSIncludesSubdomains</key>
				<true/>
				<key>NSTemporaryExceptionAllowsInsecureHTTPLoads</key>
				<false/>
			</dict>
			<key>lotus.ai</key>
			<dict>
				<key>NSIncludesSubdomains</key>
				<true/>
				<key>NSTemporaryExceptionAllowsInsecureHTTPLoads</key>
				<false/>
			</dict>
			<key>api.lotus.ai</key>
			<dict>
				<key>NSIncludesSubdomains</key>
				<true/>
				<key>NSTemporaryExceptionAllowsInsecureHTTPLoads</key>
				<false/>
			</dict>
		</dict>
	</dict>
	<key>OBD2BLEDeviceName</key>
	<string>$(OBD2BLEDeviceName)</string>
	<key>NSBluetoothAlwaysUsageDescription</key>
	<string>Trucker Easy uses Bluetooth to connect optional OBD-II or ELD adapters for engine diagnostics and fleet telemetry when you enable that feature.</string>
	<key>NSBluetoothPeripheralUsageDescription</key>
	<string>Trucker Easy uses Bluetooth to connect optional OBD-II or ELD adapters for engine diagnostics and fleet telemetry when you enable that feature.</string>
	<key>OSRMServerURL</key>
	<string>$(OSRM_SERVER_URL)</string>
	<key>OpenRouterAPIKey</key>
	<string>$(OpenRouterAPIKey)</string>
	<key>OpenWeatherMapAPIKey</key>
	<string>$(OpenWeatherMapAPIKey)</string>
	<key>OperationalFeedAPIBaseURL</key>
	<string>$(OperationalFeedAPIBaseURL)</string>
	<key>OperationalFeedAPIKey</key>
	<string>$(OperationalFeedAPIKey)</string>
	<key>OperationalFeedProviderURLs</key>
	<string>$(OperationalFeedProviderURLs)</string>
	<key>RouteOptimizationAPIBaseURL</key>
	<string>$(ROUTE_OPTIMIZATION_API_BASE_URL)</string>
	<key>RouteOptimizationAPIKey</key>
	<string>$(ROUTE_OPTIMIZATION_API_KEY)</string>
	<key>SupabaseAnonKey</key>
	<string>$(SUPABASE_ANON_KEY)</string>
	<key>SupabaseURL</key>
	<string>$(SUPABASE_URL)</string>
	<key>UIBackgroundModes</key>
	<array>
		<string>location</string>
		<string>audio</string>
		<string>remote-notification</string>
	</array>
	<key>UILaunchScreen</key>
	<dict>
		<key>UIColorName</key>
		<string>LaunchScreenBackground</string>
	</dict>
	<key>ValhallaServerURL</key>
	<string>$(VALHALLA_SERVER_URL)</string>
	<key>ValhallaServerURLs</key>
	<string>$(VALHALLA_SERVER_URLS)</string>
	<key>AppStoreURL</key>
	<string>$(APP_STORE_URL)</string>
	<key>TestFlightURL</key>
	<string>$(TESTFLIGHT_URL)</string>
	<key>LotusCortexWebBaseURL</key>
	<string>$(LOTUS_CORTEX_WEB_BASE_URL)</string>
</dict>
</plist>
